{
  "name": "worldwright",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Repository foundation for the Worldwright AI world architect.",
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "architecture-planner": "tsx packages/architecture-planner/src/cli.ts",
    "build": "pnpm --recursive build",
    "check": "pnpm format:check && pnpm lint && pnpm build && pnpm typecheck:packages && pnpm test:packages && pnpm schema:check && pnpm fixture:check:packages && pnpm test:dist:packages",
    "fixture:check": "pnpm build && pnpm fixture:check:packages",
    "fixture:check:packages": "pnpm --recursive --if-present fixture:check",
    "fixture:generate": "pnpm build && pnpm --recursive --if-present fixture:generate",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "roblox-compiler": "tsx packages/roblox-compiler/src/cli.ts",
    "schema:check": "pnpm --recursive --if-present schema:check",
    "schema:generate": "pnpm --recursive --if-present schema:generate",
    "studio-mcp": "tsx packages/studio-mcp-adapter/src/cli.ts",
    "studio:batch-live-smoke": "tsx packages/studio-mcp-adapter/scripts/live-batch-smoke.ts",
    "studio:live-smoke": "tsx packages/studio-mcp-adapter/scripts/live-smoke.ts",
    "test": "pnpm build && pnpm test:packages",
    "test:dist": "pnpm build && pnpm test:dist:packages",
    "test:dist:packages": "pnpm --recursive --if-present test:dist",
    "test:packages": "pnpm --recursive test",
    "typecheck": "pnpm build && pnpm typecheck:packages",
    "typecheck:packages": "pnpm --recursive typecheck",
    "worldspec": "tsx packages/worldspec/src/cli.ts"
  },
  "devDependencies": {
    "@eslint/js": "9.31.0",
    "eslint": "9.31.0",
    "prettier": "3.6.2",
    "tsx": "4.20.3",
    "typescript": "5.8.3",
    "typescript-eslint": "8.38.0"
  }
}
