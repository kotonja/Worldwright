{
  "$id": "urn:worldwright:studio-sandbox-lease-record:0.1.0",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "type": "object",
  "properties": {
    "schemaVersion": {
      "const": "0.1.0",
      "type": "string"
    },
    "leaseId": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    },
    "projectId": {
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$",
      "type": "string"
    },
    "changeSetHash": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    }
  },
  "required": [
    "schemaVersion",
    "leaseId",
    "projectId",
    "changeSetHash"
  ]
}
